# Database connection string
# For local development (SQLite):
DATABASE_URL=sqlite:///./workspace_manager.db

# For production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@localhost:5432/workspace_manager

# Realtime auto-sync tuning
SYNC_LOOP_INTERVAL_SECONDS=5
SYNC_STALE_MINUTES=5
SYNC_PENDING_INVITE_SECONDS=15
SYNC_BASELINE_MINUTES=5
SYNC_HOT_WINDOW_SECONDS=180
SYNC_FOLLOWUP_STEPS=5,15,30,60
SYNC_ERROR_RETRY_STEPS=10,30,60
SYNC_MAX_PARALLEL_WORKSPACES=2

# Admin authentication token
ADMIN_TOKEN=change-me-to-a-secure-random-string
